logs/test.log

# Temporary files
*.tmp
*.temp
*.bak

# Data files that might be large
data/*.csv
!data/nsl_kdd.csv  # Keep the original dataset

# Model files (can be large)
models/*.pkl
models/*.joblib

# Node modules if any
node_modules/

# Environment variables
.env
.env.local
.env.production