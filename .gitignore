# Virtual environment
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs (runtime logs, not to be committed)
logs/*.log
logs/system.log
logs/dashboard.log
logs/detector_service.log
logs/feature_extractor.log
logs/packet_sniffer.log
