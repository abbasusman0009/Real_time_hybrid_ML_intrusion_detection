# RT-IDPS Production Environment Configuration
# Copy this file to .env and update values for your deployment

# ==================== Flask Configuration ====================
# Host to bind to (use 0.0.0.0 for external access)
FLASK_HOST=0.0.0.0

# Port to run the Flask application
FLASK_PORT=5000

# Enable debug mode (NEVER use True in production)
FLASK_DEBUG=False

# ==================== Security Configuration ====================
# Secret key for session encryption (generate a strong random key)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secure-random-key-here-minimum-32-characters

# Admin username
ADMIN_USERNAME=admin

# Admin password hash (generate with: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))")
# Example for password "admin123":
ADMIN_PASSWORD_HASH=$2b$12$your-generated-hash-here

# ==================== Network Configuration ====================
# Network interface to monitor for packet capture
# Examples: eth0, ens0, wlan0 (leave as eth0 for Render)
NETWORK_INTERFACE=eth0

# ==================== CORS Configuration ====================
# Comma-separated list of allowed origins for CORS
# Example: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# ==================== Logging Configuration ====================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== Database/Storage (Future) ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/rt_idps
# REDIS_URL=redis://localhost:6379/0

# ==================== Deployment Platform ====================
# For Render deployment, ensure these are set correctly
ENV=production
